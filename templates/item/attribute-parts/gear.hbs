{{! Attributes Tab }}
<section
  class='tab attributes {{tab.cssClass}}'
  data-group='primary'
  data-tab='attributes'
>
  <div class='form-group'>
    <label>{{localize 'DIE_RPG.Item.Gear.FIELDS.defenseBonus.label'}}</label>
    <input
      type='number'
      name='system.defenseBonus'
      value='{{system.defenseBonus}}'
      data-dtype='Number'
      min='0'
    />
  </div>

  <div class='form-group'>
    <label>{{localize 'DIE_RPG.Item.Gear.FIELDS.rollModType.label'}}</label>
    <select name='system.rollModType'>
      {{#select system.rollModType}}
        <option value='none'>None</option>
        <option value='advantage'>Advantage</option>
        <option value='disadvantage'>Disadvantage</option>
        <option value='add_dice'>Add Dice</option>
      {{/select}}
    </select>
  </div>

  {{#if (eq system.rollModType 'add_dice')}}
    <div class='form-group'>
      <label>{{localize 'DIE_RPG.Item.Gear.FIELDS.rollModValue.label'}}</label>
      <input
        type='number'
        name='system.rollModValue'
        value='{{system.rollModValue}}'
        data-dtype='Number'
      />
    </div>
  {{/if}}

  <div class='form-group'>
    <label>{{localize 'DIE_RPG.Item.Gear.FIELDS.specialText.label'}}</label>
    <input
      type='text'
      name='system.specialText'
      value='{{system.specialText}}'
    />
  </div>

</section>