{{!-- Specials Tab --}}
<section class="tab specials {{tab.cssClass}}"  data-group="primary" data-tab="specials" data-subtype="{{document.type}}">
  <h2>{{localize 'DIE_RPG.Item.Paragon.FIELDS.specials.label'}}</h2>
  <p class="hint">{{localize "DIE_RPG.UI.Hints.SpecialsDescription"}}</p>

  <ol class="specials-list">
    {{#each system.specials as |special index|}}
      <li class="special-item {{#if special.mandatory}}mandatory{{/if}}" data-index="{{index}}">
        <div class="special-header">
          <div class="special-main-fields">
            <div class="form-group">
              <label>{{localize 'DIE_RPG.Shared.special.name.label'}}</label>
              <input type="text" name="system.specials.{{index}}.name" value="{{special.name}}" placeholder="{{localize 'DIE_RPG.UI.Placeholders.SpecialName'}}" />
            </div>
          </div>
        </div>

        <div class="special-options">
          <div class="form-group">
            <label>{{localize 'DIE_RPG.Shared.special.cost.label'}}</label>
            <select name="system.specials.{{index}}.cost">
              {{selectOptions @root.config.specialCostTypes selected=special.cost localize=true blank=""}}
            </select>
            <span class="hint">{{localize 'DIE_RPG.Shared.special.cost.hint'}}</span>
          </div>
          <div class="form-group checkbox">
            <label>
              <input type="checkbox" name="system.specials.{{index}}.mandatory" {{checked special.mandatory}} />
              {{localize 'DIE_RPG.Shared.special.mandatory.label'}}
            </label>
            <span class="hint">{{localize 'DIE_RPG.Shared.special.mandatory.hint'}}</span>
          </div>
        </div>

        <div class="form-group stacked">
          <label>{{localize 'DIE_RPG.Shared.special.description.label'}}</label>
          <div class="editor scroll-indicators">
            <prose-mirror
              name="system.specials.{{index}}.description"
              data-document-uuid="{{item.uuid}}"
              value="{{special.description}}"
              toggled="true"
              compact="true">
              {{{lookup @root.enrichedSpecialDescriptions index}}}
            </prose-mirror>
          </div>
        </div>

        <button type="button" class="delete-special" data-action="deleteSpecial" data-index="{{index}}" title="{{localize 'DIE_RPG.UI.Tooltips.DeleteSpecial'}}">
          <i class="fas fa-trash"></i> {{localize "DIE_RPG.UI.Buttons.Delete"}}
        </button>
      </li>
    {{/each}}
  </ol>

  {{#if (eq system.specials.length 0)}}
    <p class="no-items">{{localize "DIE_RPG.UI.EmptyStates.NoSpecialsDefined"}}</p>
  {{/if}}

  <button type="button" class="add-special" data-action="addSpecial">
    <i class="fas fa-plus"></i> {{localize 'DIE_RPG.Item.Paragon.AddSpecial'}}
  </button>
</section>
