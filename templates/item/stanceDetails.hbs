{{!-- Stance Details Tab --}}
<section class="tab stanceDetails {{tab.cssClass}}" data-group="primary" data-tab="stanceDetails" data-subtype="{{document.type}}">
  <div class='form-group checkbox'>
    <label>
      <input type='checkbox' name='system.active' {{checked system.active}} />
      {{localize 'DIE_RPG.Item.Stance.FIELDS.active.label'}}
    </label>
    <p class="hint">{{localize 'DIE_RPG.Item.Stance.FIELDS.active.hint'}}</p>
  </div>

  <div class='form-group'>
    <label>{{localize 'DIE_RPG.Item.Stance.FIELDS.stanceType.label'}}</label>
    <select name='system.stanceType'>
      {{selectOptions
        config.stanceTypes
        selected=system.stanceType
        localize=true
      }}
    </select>
    <p class="hint">{{localize 'DIE_RPG.Item.Stance.FIELDS.stanceType.hint'}}</p>
  </div>

  {{#if (eq system.stanceType 'EMOTION')}}
    <div class='form-group'>
      <label>{{localize 'DIE_RPG.Item.Stance.FIELDS.emotionSubtype.label'}}</label>
      <input
        type='text'
        name='system.emotionSubtype'
        value='{{system.emotionSubtype}}'
        list='emotionSubtypeList'
        placeholder='{{localize "DIE_RPG.Item.Stance.FIELDS.emotionPlaceholder"}}'
      />
      <datalist id='emotionSubtypeList'>
        <option value='ECSTASY/JOY/SERENITY'></option>
        <option value='GRIEF/SADNESS/PENSIVENESS'></option>
        <option value='ADMIRATION/TRUST/ACCEPTANCE'></option>
        <option value='LOATHING/DISGUST/BOREDOM'></option>
        <option value='TERROR/FEAR/APPREHENSION'></option>
        <option value='RAGE/ANGER/ANNOYANCE'></option>
        <option value='VIGILANCE/ANTICIPATION/INTEREST'></option>
        <option value='AMAZEMENT/SURPRISE/DISTRACTION'></option>
      </datalist>
      <p class="hint">{{localize 'DIE_RPG.Item.Stance.FIELDS.emotionSubtype.hint'}}</p>
    </div>
  {{/if}}
</section>
