{{! Paragon Form Definitions Tab }}
<section
	class="tab abilities {{tab.cssClass}}"
	data-group="primary"
	data-tab="abilities"
	data-subtype="{{document.type}}"
>
	{{! Class Abilities Form Fields }}
	<fieldset class="form-section class-abilities-fields">
		<legend>{{localize "DIE_RPG.Item.Paragon.Documentation.ClassAbilities.Legend"}}</legend>
		<p class="hint">{{{localize "DIE_RPG.Item.Paragon.Documentation.ClassAbilities.Description"}}}</p>

		<div class="form-group stacked">
			{{!-- <label>Class Abilities Fields (JSON)</label> --}}
			<textarea
				name="system.classAbilities.fields"
				rows="10"
				class="json-editor"
				placeholder='[{"key": "exampleField", "type": "text", "label": "Example Field", "initial": ""}]'
			>{{json system.classAbilities.fields space=2}}</textarea>
			<p class="hint">
				{{localize "DIE_RPG.Item.Paragon.Documentation.ClassAbilities.SeeReference"}}
			</p>
		</div>

		{{! Field Type Reference }}
		<details class="field-type-reference">
			<summary>{{localize "DIE_RPG.Item.Paragon.Documentation.FieldReference.Summary"}}</summary>
			<div class="reference-content">
				<p>
					<strong>{{localize "DIE_RPG.Item.Paragon.Documentation.FieldReference.AvailableTypes"}}</strong>
					{{localize "DIE_RPG.Item.Paragon.Documentation.FieldReference.AvailableTypesList"}}<br
					/>
					<strong>{{localize "DIE_RPG.Item.Paragon.Documentation.FieldReference.RequiredProperties"}}</strong>
					{{localize "DIE_RPG.Item.Paragon.Documentation.FieldReference.RequiredPropertiesList"}}<br />
					<strong>{{localize "DIE_RPG.Item.Paragon.Documentation.FieldReference.OptionalProperties"}}</strong>
					{{localize "DIE_RPG.Item.Paragon.Documentation.FieldReference.OptionalPropertiesList"}}
				</p>
				<h4>{{localize "DIE_RPG.Item.Paragon.Documentation.FieldReference.TextFieldHeading"}}</h4>
				<pre><code>{ "key": "myTextField", "type": "text", "label": "My Text Field",
						"initial": "", "hint": "Optional help text" }</code></pre>

				<h4>{{localize "DIE_RPG.Item.Paragon.Documentation.FieldReference.NumberFieldHeading"}}</h4>
				<pre><code>{ "key": "myNumber", "type": "number", "label": "My Number",
						"initial": 0, "min": 0, "max": 10 }</code></pre>

				<h4>{{localize "DIE_RPG.Item.Paragon.Documentation.FieldReference.BooleanFieldHeading"}}</h4>
				<pre><code>{ "key": "myCheckbox", "type": "boolean", "label": "Enable
						Feature", "initial": false }</code></pre>

				<h4>{{localize "DIE_RPG.Item.Paragon.Documentation.FieldReference.SelectFieldHeading"}}</h4>
				<pre><code>{ "key": "mySelect", "type": "select", "label": "Choose Option",
						"choices": ["Option 1", "Option 2", "Option 3"], "initial": "" }</code></pre>

				<h4>{{localize "DIE_RPG.Item.Paragon.Documentation.FieldReference.MultiSelectFieldHeading"}}</h4>
				<pre><code>{ "key": "myMultiSelect", "type": "multiSelect", "label": "Choose
						Multiple", "choices": ["Choice A", "Choice B", "Choice C"], "initial": [],
						"description": "&lt;p&gt;Optional &lt;strong&gt;HTML&lt;/strong&gt; description shown above the field.&lt;/p&gt;" }</code></pre>

				<h4>{{localize "DIE_RPG.Item.Paragon.Documentation.FieldReference.HTMLFieldHeading"}}</h4>
				<pre><code>{ "key": "myRichText", "type": "html", "label": "Description",
						"initial": "" }</code></pre>

				<h4>{{localize "DIE_RPG.Item.Paragon.Documentation.FieldReference.InfoFieldHeading"}}</h4>
				<pre><code>{ "key": "myInfo", "type": "info", "label": "Information",
						"description": "&lt;p&gt;Static content displayed to the user.&lt;/p&gt;" }</code></pre>

				<h4>{{localize "DIE_RPG.Item.Paragon.Documentation.FieldReference.GroupFieldHeading"}}</h4>
				<pre><code>{ "key": "myGroup", "type": "group", "label": "Grouped Fields",
						"fields": [ {"key": "subField1", "type": "text", "label": "Sub Field 1"},
						{"key": "subField2", "type": "number", "label": "Sub Field 2"} ] }</code></pre>

				<h4>{{localize "DIE_RPG.Item.Paragon.Documentation.FieldReference.ItemListFieldHeading"}}</h4>
				<pre><code>{ "key": "myItems", "type": "itemList", "label": "My Items",
						"itemType": "spell" }</code></pre>

				<h4>{{localize "DIE_RPG.Item.Paragon.Documentation.FieldReference.SpecialFieldHeading"}}</h4>
				<pre><code>{ "key": "mySpecial", "type": "special", "label": "Special
						Ability", "specialKey": "neotech" }</code></pre>
			</div>
		</details>
	</fieldset>

	{{! JSON Validation Helper }}
	<div class="json-validation-hint">
		<p>
			<i class="fas fa-info-circle"></i>
			<strong>{{localize "DIE_RPG.Item.Paragon.Documentation.ValidationTip.TipLabel"}}</strong>
			{{localize "DIE_RPG.Item.Paragon.Documentation.ValidationTip.TipText"}}
		</p>
	</div>
</section>