{{!-- Paragon Equipment Options Tab --}}
<section class="tab eqParagonOptions {{tab.cssClass}}" data-group="primary" data-tab="eqParagonOptions" data-subtype="{{document.type}}">
  <h2>{{localize 'DIE_RPG.UI.Headers.EquipmentOptions'}}</h2>
  <p class="hint">{{localize "DIE_RPG.UI.Hints.DragEquipmentHere"}}</p>

  {{> "systems/die-rpg/templates/partials/item-list.hbs"
      items=resolvedEquipment
      label=""
      itemType="equipment"
      showCheckboxes=false
      showCreateButton=false
      showEditButton=false
      deleteAction="removeEquipmentOption"
      editable=true}}
</section>
