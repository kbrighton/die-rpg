{{! Paragon Details Tab }}
<section
	class="tab paragonDetails {{tab.cssClass}}"
	data-group="primary"
	data-tab="paragonDetails"
	data-subtype="{{document.type}}"
>
	{{!-- <h2>{{localize 'DIE_RPG.Item.Paragon.Details.label'}}</h2> --}}
	{{! Core Nature }}
	<div class="form-group stacked">
		<label>{{localize "DIE_RPG.Item.Paragon.FIELDS.coreNature.label"}}</label>
		<div class="editor scroll-indicators">
			{{#if editable}}
				<prose-mirror
					name="system.coreNature"
					data-document-u-u-i-d="{{item.uuid}}"
					value="{{system.coreNature}}"
					collaborate="true"
					toggled="true"
					compact="true"
				>
					{{{enrichedCoreNature}}}
				</prose-mirror>
			{{else}}
				{{{enrichedCoreNature}}}
			{{/if}}
		</div>
		<p class="hint">{{localize "DIE_RPG.Item.Paragon.FIELDS.coreNature.hint"}}</p>
	</div>

	{{! Die Type }}
	<div class="form-group">
		<label>{{localize "DIE_RPG.Item.Paragon.FIELDS.die.label"}}</label>
		<select name="system.die">
			{{selectOptions config.dieTypes selected=system.die blank=""}}
		</select>
		<p class="hint">{{localize "DIE_RPG.Item.Paragon.FIELDS.die.hint"}}</p>
	</div>

	{{! Important Stat }}
	<div class="form-group">
		<label>{{localize "DIE_RPG.Item.Paragon.FIELDS.importantStat.label"}}</label>
		<select name="system.importantStat">
			{{selectOptions
				config.stats
				selected=system.importantStat
				localize=true
				blank=""
			}}
		</select>
		<p class="hint">{{localize
				"DIE_RPG.Item.Paragon.FIELDS.importantStat.hint"
			}}</p>
	</div>

	{{! Secondary Important Stat }}
	<div class="form-group">
		<label>{{localize "DIE_RPG.Item.Paragon.FIELDS.importantStat2.label"}}</label>
		<select name="system.importantStat2">
			{{selectOptions
				config.stats
				selected=system.importantStat2
				localize=true
				blank=""
			}}
		</select>
		<p class="hint">{{localize
				"DIE_RPG.Item.Paragon.FIELDS.importantStat2.hint"
			}}</p>
	</div>

	{{! Core Ability }}
	<fieldset class="core-ability">
		<legend>{{localize "DIE_RPG.Item.Paragon.FIELDS.coreAbility.label"}}</legend>

		<div class="form-group">
			<label>{{localize
					"DIE_RPG.Item.Paragon.FIELDS.coreAbility.name.label"
				}}</label>
			<input
				type="text"
				name="system.coreAbility.name"
				value="{{system.coreAbility.name}}"
			/>
		</div>

		<div class="form-group stacked">
			<label>{{localize
					"DIE_RPG.Item.Paragon.FIELDS.coreAbility.description.label"
				}}</label>
			<div class="editor scroll-indicators">
				{{#if editable}}
					<prose-mirror
						name="system.coreAbility.description"
						data-document-u-u-i-d="{{item.uuid}}"
						value="{{system.coreAbility.description}}"
						collaborate="true"
						toggled="true"
						compact="true"
					>
						{{{enrichedCoreAbilityDescription}}}
					</prose-mirror>
				{{else}}
					{{{enrichedCoreAbilityDescription}}}
				{{/if}}
			</div>
		</div>
	</fieldset>

	{{! Optional: Theme Images }}
	<fieldset class="form-section theme-images">
		<legend>{{localize "DIE_RPG.UI.Hints.ThemeImagesLegend"}}</legend>
		<p class="hint">{{localize "DIE_RPG.UI.Hints.ThemeImagesHint"}}</p>

		<div class="form-group">
			<label>{{localize "DIE_RPG.UI.Hints.ClassDiceImageLabel"}}</label>
			<div class="form-fields">
				<input
					type="text"
					name="system.classDiceImage"
					value="{{system.classDiceImage}}"
					placeholder="{{localize 'DIE_RPG.UI.Placeholders.ClassDiceImagePath'}}"
				/>
				<button
					type="button"
					class="file-picker-button"
					data-action="browseImage"
					data-target="system.classDiceImage"
					data-tooltip="{{localize 'DIE_RPG.UI.Tooltips.BrowseForImage'}}"
				>
					<i class="fas fa-file-image"></i>
				</button>
			</div>
			<p class="hint">{{localize "DIE_RPG.Item.Paragon.FIELDS.classDiceImage.hint"}}</p>
		</div>

		<div class="form-group">
			<label>{{localize "DIE_RPG.UI.Hints.PortraitImageLabel"}}</label>
			<div class="form-fields">
				<input
					type="text"
					name="system.portraitImage"
					value="{{system.portraitImage}}"
					placeholder="{{localize 'DIE_RPG.UI.Placeholders.PortraitImagePath'}}"
				/>
				<button
					type="button"
					class="file-picker-button"
					data-action="browseImage"
					data-target="system.portraitImage"
					data-tooltip="{{localize 'DIE_RPG.UI.Tooltips.BrowseForImage'}}"
				>
					<i class="fas fa-file-image"></i>
				</button>
			</div>
			<p class="hint">{{localize "DIE_RPG.Item.Paragon.FIELDS.portraitImage.hint"}}</p>
		</div>

		<div class="form-group">
			<label>{{localize "DIE_RPG.UI.Hints.TokenImageLabel"}}</label>
			<div class="form-fields">
				<input
					type="text"
					name="system.tokenImage"
					value="{{system.tokenImage}}"
					placeholder="{{localize 'DIE_RPG.UI.Placeholders.TokenImagePath'}}"
				/>
				<button
					type="button"
					class="file-picker-button"
					data-action="browseImage"
					data-target="system.tokenImage"
					data-tooltip="{{localize 'DIE_RPG.UI.Tooltips.BrowseForImage'}}"
				>
					<i class="fas fa-file-image"></i>
				</button>
			</div>
			<p class="hint">{{localize "DIE_RPG.Item.Paragon.FIELDS.tokenImage.hint"}}</p>
		</div>
	</fieldset>
</section>