<section
	class="tab description {{tab.cssClass}}"
	data-group="primary"
	data-tab="description"
	data-subtype="{{document.type}}"
>
	{{!-- <h2>{{localize 'DIE_RPG.Item.FIELDS.Description.label'}}</h2> --}}
	{{#if editable}}
		<prose-mirror
			name="system.description"
			data-document-u-u-i-d="{{item.uuid}}"
			value="{{system.description}}"
			collaborate="true"
			toggled="true"
      compact="true"
		>
			{{{enrichedDescription}}}
		</prose-mirror>
	{{else}}
		{{{enrichedDescription}}}
	{{/if}}
</section>