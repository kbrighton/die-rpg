{{!-- Main Body Template for Paragon Items --}}
<div class="sheet-body die-rpg item paragon">

  {{!-- Tab Navigation --}}
  <nav class="tabs" data-group="primary">
    <a class="item active" data-tab="details"><i class="fas fa-info-circle"></i> Details</a>
    <a class="item" data-tab="looks"><i class="fas fa-tshirt"></i> Looks</a>
    <a class="item" data-tab="specials"><i class="fas fa-star"></i> Specials</a>
    <a class="item" data-tab="advancements"><i class="fas fa-sitemap"></i> Advancements</a>
    <a class="item" data-tab="description"><i class="fas fa-book"></i> Description</a>
  </nav>

  {{!-- Tab Content --}}
  <section class="sheet-tabs tabs-content">

    {{!-- Details Tab --}}
    <div class="tab active" data-group="primary" data-tab="details">
      <section class="paragon-details">

        {{!-- Core Nature --}}
        <div class="form-group stacked">
          <label>{{localize 'DIE_RPG.Item.Paragon.FIELDS.coreNature.label'}}</label>
          <div class="editor">
            {{editor system.coreNature target="system.coreNature" button=true editable=editable}}
          </div>
          <p class="hint">{{localize 'DIE_RPG.Item.Paragon.FIELDS.coreNature.hint'}}</p>
        </div>

        {{!-- Die Type --}}
        <div class="form-group">
          <label>{{localize 'DIE_RPG.Item.Paragon.FIELDS.die.label'}}</label>
          <select name="system.die">
            {{selectOptions config.dieTypes selected=system.die blank=""}}
          </select>
          <p class="hint">{{localize 'DIE_RPG.Item.Paragon.FIELDS.die.hint'}}</p>
        </div>

        {{!-- Important Stat --}}
        <div class="form-group">
          <label>{{localize 'DIE_RPG.Item.Paragon.FIELDS.importantStat.label'}}</label>
          <select name="system.importantStat">
            {{selectOptions config.stats selected=system.importantStat localize=true blank=""}}
          </select>
          <p class="hint">{{localize 'DIE_RPG.Item.Paragon.FIELDS.importantStat.hint'}}</p>
        </div>

        {{!-- Core Ability --}}
        <fieldset class="core-ability">
          <legend>{{localize 'DIE_RPG.Item.Paragon.FIELDS.coreAbility.label'}}</legend>

          <div class="form-group">
            <label>{{localize 'DIE_RPG.Item.Paragon.FIELDS.coreAbility.name.label'}}</label>
            <input type="text" name="system.coreAbility.name" value="{{system.coreAbility.name}}" />
          </div>

          <div class="form-group stacked">
            <label>{{localize 'DIE_RPG.Item.Paragon.FIELDS.coreAbility.description.label'}}</label>
            <div class="editor">
              {{editor system.coreAbility.description target="system.coreAbility.description" button=true editable=editable}}
            </div>
          </div>
        </fieldset>

      </section>
    </div>

    {{!-- Looks Tab --}}
    <div class="tab" data-group="primary" data-tab="looks">
      <section class="paragon-looks">
        <h3>{{localize 'DIE_RPG.Item.Paragon.FIELDS.looks.label'}}</h3>
        <p class="hint">Appearance/clothing options that characters can choose from.</p>

        <ol class="looks-list">
          {{#each system.looks as |look index|}}
            <li class="look-item" data-index="{{index}}">
              <div class="look-header">
                <span class="look-number">{{add index 1}}.</span>
                <div class="look-fields">
                  <div class="form-group">
                    <label>{{localize 'DIE_RPG.Item.Paragon.FIELDS.look.name.label'}}</label>
                    <input type="text" name="system.looks.{{index}}.name" value="{{look.name}}" placeholder="e.g., Leather Jacket" />
                  </div>
                  <div class="form-group">
                    <label>{{localize 'DIE_RPG.Item.Paragon.FIELDS.look.description.label'}}</label>
                    <input type="text" name="system.looks.{{index}}.description" value="{{look.description}}" placeholder="Optional description" />
                  </div>
                  <div class="form-group">
                    <label>{{localize 'DIE_RPG.Item.Paragon.FIELDS.look.defenseBonus.label'}}</label>
                    <input type="number" name="system.looks.{{index}}.defenseBonus" value="{{look.defenseBonus}}" min="0" />
                  </div>
                </div>
                <button type="button" class="delete-look" data-action="deleteLook" data-index="{{index}}" title="Delete Look">
                  <i class="fas fa-trash"></i>
                </button>
              </div>
            </li>
          {{/each}}
        </ol>

        {{#if (eq system.looks.length 0)}}
          <p class="no-items">No looks defined. Add one below.</p>
        {{/if}}

        <button type="button" class="add-look" data-action="addLook">
          <i class="fas fa-plus"></i> {{localize 'DIE_RPG.Item.Paragon.AddLook'}}
        </button>
      </section>
    </div>

    {{!-- Specials Tab --}}
    <div class="tab" data-group="primary" data-tab="specials">
      <section class="paragon-specials">
        <h3>{{localize 'DIE_RPG.Item.Paragon.FIELDS.specials.label'}}</h3>
        <p class="hint">Special abilities that can be activated when rolling 6+ on dice.</p>

        <ol class="specials-list">
          {{#each system.specials as |special index|}}
            <li class="special-item {{#if special.mandatory}}mandatory{{/if}}" data-index="{{index}}">
              <div class="special-header">
                <span class="special-number">{{add index 1}}.</span>
                <div class="special-main-fields">
                  <div class="form-group">
                    <label>{{localize 'DIE_RPG.Item.Paragon.FIELDS.special.name.label'}}</label>
                    <input type="text" name="system.specials.{{index}}.name" value="{{special.name}}" placeholder="Special name" />
                  </div>
                  <div class="form-group">
                    <label>{{localize 'DIE_RPG.Item.Paragon.FIELDS.special.key.label'}}</label>
                    <input type="text" name="system.specials.{{index}}.key" value="{{special.key}}" placeholder="e.g., neotech (optional)" />
                  </div>
                </div>
              </div>

              <div class="special-options">
                <div class="form-group">
                  <label>{{localize 'DIE_RPG.Item.Paragon.FIELDS.special.cost.label'}}</label>
                  <input type="number" name="system.specials.{{index}}.cost" value="{{special.cost}}" min="1" max="4" />
                  <span class="hint">{{localize 'DIE_RPG.Item.Paragon.FIELDS.special.cost.hint'}}</span>
                </div>
                <div class="form-group checkbox">
                  <label>
                    <input type="checkbox" name="system.specials.{{index}}.mandatory" {{checked special.mandatory}} />
                    {{localize 'DIE_RPG.Item.Paragon.FIELDS.special.mandatory.label'}}
                  </label>
                  <span class="hint">{{localize 'DIE_RPG.Item.Paragon.FIELDS.special.mandatory.hint'}}</span>
                </div>
              </div>

              <div class="form-group stacked">
                <label>{{localize 'DIE_RPG.Item.Paragon.FIELDS.special.description.label'}}</label>
                <div class="editor">
                  {{editor special.description target=(concat "system.specials." index ".description") button=true editable=editable}}
                </div>
              </div>

              <button type="button" class="delete-special" data-action="deleteSpecial" data-index="{{index}}" title="Delete Special">
                <i class="fas fa-trash"></i> Delete
              </button>
            </li>
          {{/each}}
        </ol>

        {{#if (eq system.specials.length 0)}}
          <p class="no-items">No specials defined. Add one below.</p>
        {{/if}}

        <button type="button" class="add-special" data-action="addSpecial">
          <i class="fas fa-plus"></i> {{localize 'DIE_RPG.Item.Paragon.AddSpecial'}}
        </button>
      </section>
    </div>

    {{!-- Advancements Tab --}}
    <div class="tab" data-group="primary" data-tab="advancements">
      <section class="paragon-advancements">
        <h3>{{localize 'DIE_RPG.Item.Paragon.FIELDS.advancements.label'}}</h3>
        <p class="hint">This is where advancement editing will go. For now, advancements can be edited via the advancement accordion on character sheets.</p>

        {{!-- TODO: Add advancement pool editor here --}}
        {{!-- TODO: Add advancement map assignment editor here --}}

        <p class="notice">
          <i class="fas fa-info-circle"></i>
          Advanced editing coming soon. Current advancements are managed through the character sheet.
        </p>
      </section>
    </div>

    {{!-- Description Tab --}}
    <div class="tab" data-group="primary" data-tab="description">
      <section class="description">
        <div class="form-group stacked">
          <label>Description</label>
          <div class="editor">
            {{editor enrichedDescription target="system.description" button=true editable=editable}}
          </div>
        </div>
      </section>
    </div>

  </section>

</div>
