{{!--
  Partial template for a single special item editor

  Parameters:
  - special: The special object data
  - index: The index in the specials array
  - basePath: The base name path (e.g., "system.specials" or "system.abilities.0.specials")
  - documentUuid: The document UUID for prose-mirror
  - editable: Whether the form is editable
  - deleteAction: The action name for the delete button (default: "deleteSpecial")
  - deleteDataAttrs: Additional data attributes for delete button (e.g., "data-ability-index='0'")
--}}
<div class="special-item {{#if special.mandatory}}mandatory{{/if}}" data-special-index="{{index}}">
  {{! Name field with inline delete button }}
  <div class="special-name-row">
    <input
      type="text"
      name="{{basePath}}.{{index}}.name"
      value="{{special.name}}"
      placeholder="{{localize 'DIE_RPG.UI.Placeholders.SpecialName'}}"
      {{#unless editable}}disabled{{/unless}}
    />
    {{#if editable}}
      <button
        type="button"
        class="delete-special-btn"
        data-action="{{#if deleteAction}}{{deleteAction}}{{else}}deleteSpecial{{/if}}"
        data-special-index="{{index}}"
        {{{deleteDataAttrs}}}
        title="{{localize 'DIE_RPG.UI.Tooltips.DeleteSpecial'}}"
      >
        <i class="fas fa-trash"></i>
      </button>
    {{/if}}
  </div>

  {{! Special type and mandatory checkbox in one row }}
  <div class="special-options-row">
    <div class="form-field-inline">
      <label>{{localize 'DIE_RPG.Shared.special.cost.label'}}</label>
      <select name="{{basePath}}.{{index}}.cost" {{#unless editable}}disabled{{/unless}}>
        {{selectOptions @root.config.specialCostTypes selected=special.cost localize=true blank=""}}
      </select>
    </div>
    <div class="form-group checkbox">
      <label>
        <input
          type="checkbox"
          name="{{basePath}}.{{index}}.mandatory"
          {{checked special.mandatory}}
          {{#unless editable}}disabled{{/unless}}
        />
        {{localize 'DIE_RPG.Shared.special.mandatory.label'}}
      </label>
    </div>
  </div>

  {{! Description field }}
  <div class="special-description">
    <label>{{localize 'DIE_RPG.Shared.special.description.label'}}</label>
    <div class="editor scroll-indicators">
      {{#if editable}}
        <prose-mirror
          name="{{basePath}}.{{index}}.description"
          data-document-uuid="{{documentUuid}}"
          value="{{special.description}}"
          collaborate="true"
          toggled="true"
          compact="true">
          {{{special.description}}}
        </prose-mirror>
      {{else}}
        {{{special.description}}}
      {{/if}}
    </div>
  </div>
</div>
