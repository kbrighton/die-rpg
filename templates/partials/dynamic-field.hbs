{{!-- Dynamic Field Renderer --}}
{{!-- Renders a form field based on field definition from paragon item --}}
{{!--
  @param {Object} field - Field definition from paragon (with type, label, initial, etc.)
  @param {*} value - Current value from character data
  @param {String} path - Form path for name attribute (e.g., "system.paragon.classAbilityData.fairGold")
  @param {Boolean} editable - Whether the field is editable
--}}

{{#if (eq field.type "text")}}
  <div class="form-group">
    <label>{{field.label}}</label>
    <input type="text" name="{{path}}" value="{{value}}" data-dtype="String" {{#unless editable}}disabled{{/unless}} />
    {{#if field.hint}}<p class="hint">{{field.hint}}</p>{{/if}}
  </div>

{{else if (eq field.type "number")}}
  <div class="form-group">
    <label>{{field.label}}</label>
    <input
      type="number"
      name="{{path}}"
      value="{{value}}"
      data-dtype="Number"
      {{#if field.min}}min="{{field.min}}"{{/if}}
      {{#if field.max}}max="{{field.max}}"{{/if}}
      {{#unless editable}}disabled{{/unless}}
    />
    {{#if field.hint}}<p class="hint">{{field.hint}}</p>{{/if}}
  </div>

{{else if (eq field.type "boolean")}}
  <div class="form-group checkbox-field">
    <label>
      <input type="checkbox" name="{{path}}" data-dtype="Boolean" {{checked value}} {{#unless editable}}disabled{{/unless}} />
      {{field.label}}
    </label>
    {{#if field.hint}}<p class="hint">{{field.hint}}</p>{{/if}}
  </div>

{{else if (eq field.type "select")}}
  <div class="form-group">
    <label>{{field.label}}</label>
    <select name="{{path}}" data-dtype="String" {{#unless editable}}disabled{{/unless}}>
      <option value="">{{localize "DIE_RPG.UI.DynamicField.SelectDefault"}}</option>
      {{#each field.choices as |choice|}}
        <option value="{{choice}}" {{#if (eq choice ../value)}}selected{{/if}}>{{choice}}</option>
      {{/each}}
    </select>
    {{#if field.hint}}<p class="hint">{{field.hint}}</p>{{/if}}
  </div>

{{else if (eq field.type "multiSelect")}}
  <div class="form-group multiselect-field">
    <label>{{field.label}}</label>
    <div class="checkbox-group">
      {{#each field.choices as |choice|}}
        <label class="checkbox-option">
          <input
            type="checkbox"
            data-multi-select="{{../path}}"
            value="{{choice}}"
            {{#if (contains ../value choice)}}checked{{/if}}
            {{#unless ../editable}}disabled{{/unless}}
          />
          <span>{{choice}}</span>
        </label>
      {{/each}}
    </div>
    {{#if field.hint}}<p class="hint">{{field.hint}}</p>{{/if}}
  </div>

{{else if (eq field.type "html")}}
  <div class="form-group html-field">
    <label>{{field.label}}</label>
    {{#if editable}}
      <prose-mirror
        name="{{path}}"
        data-document-u-u-i-d="{{@root.actor.uuid}}"
        value="{{value}}"
        collaborate="true"
        toggled="true"
        compact="true"
      >
        {{{enrichedValue}}}
      </prose-mirror>
    {{else}}
      {{{enrichedValue}}}
    {{/if}}
    {{#if field.hint}}<p class="hint">{{field.hint}}</p>{{/if}}
  </div>

{{else if (eq field.type "info")}}
  <div class="form-group info-field">
    <label>{{field.label}}</label>
    <div class="info-content">
      {{{enrichedValue}}}
    </div>
    {{#if field.hint}}<p class="hint">{{field.hint}}</p>{{/if}}
  </div>

{{else if (eq field.type "itemList")}}
  <div class="form-group itemlist-field">
    <div class="itemlist-header">
      <label>{{field.label}}</label>
      {{#if editable}}
        <button
          type="button"
          class="create-item-btn"
          data-action="createItemForList"
          data-item-type="{{field.itemType}}"
          title="{{localize 'DIE_RPG.UI.DynamicField.CreateNew' type=field.itemType}}">
          <i class="fas fa-plus"></i> {{localize "DIE_RPG.UI.DynamicField.CreateButton" type=field.itemType}}
        </button>
      {{/if}}
    </div>
    {{#with (filterItemsByType actor.items field.itemType) as |filteredItems|}}
      {{#if filteredItems.length}}
        <div class="checkbox-group item-list">
          {{#each filteredItems as |item|}}
            <div class="item-row" data-item-uuid="{{item.uuid}}">
              <div class="item-row-header">
                <input
                  type="checkbox"
                  class="item-checkbox-input"
                  data-multi-select="{{../../path}}"
                  value="{{item.uuid}}"
                  {{#if (contains ../../value item.uuid)}}checked{{/if}}
                  {{#unless ../../editable}}disabled{{/unless}}
                />
                <div class="item-row-clickable" data-action="toggleItemDetails" data-item-uuid="{{item.uuid}}">
                  <img src="{{item.img}}" alt="{{item.name}}" class="item-icon" />
                  <span class="item-name">{{item.name}}</span>
                  <span class="item-type-badge">{{item.type}}</span>
                  <i class="fas fa-chevron-down expand-indicator"></i>
                </div>

                {{!-- Action buttons --}}
                {{#if ../../editable}}
                  <div class="item-actions">
                    <button
                      type="button"
                      class="item-action-btn edit-btn"
                      data-action="viewDoc"
                      data-document-uuid="{{item.uuid}}"
                      title="{{localize 'DIE_RPG.UI.DynamicField.EditItem' name=item.name}}">
                      <i class="fas fa-edit"></i>
                    </button>
                    <button
                      type="button"
                      class="item-action-btn delete-btn"
                      data-action="deleteDoc"
                      data-document-uuid="{{item.uuid}}"
                      title="{{localize 'DIE_RPG.UI.DynamicField.DeleteItem' name=item.name}}">
                      <i class="fas fa-trash"></i>
                    </button>
                  </div>
                {{/if}}
              </div>

              {{!-- Expandable details section --}}
              <div class="item-details" data-uuid="{{item.uuid}}" style="display: none;">
                <div class="item-details-content">
                  {{!-- Description (enriched HTML) --}}
                  {{#if item.system.description}}
                    <div class="item-description">
                      <strong>{{localize "DIE_RPG.UI.DynamicField.DescriptionLabel"}}</strong>
                      <div class="description-content">
                        {{{lookup @root.enrichedItemDescriptions item.id}}}
                      </div>
                    </div>
                  {{/if}}

                  {{!-- Type-specific fields --}}
                  {{#if (eq item.type "stance")}}
                    <p><strong>{{localize "DIE_RPG.UI.DynamicField.StanceTypeLabel"}}</strong> {{item.system.stanceType}}</p>
                    {{#if item.system.emotionSubtype}}
                      <p><strong>{{localize "DIE_RPG.UI.DynamicField.EmotionLabel"}}</strong> {{item.system.emotionSubtype}}</p>
                    {{/if}}
                  {{else if (eq item.type "arcaneweapon")}}
                    {{#if item.system.weaponType}}
                      <p><strong>{{localize "DIE_RPG.UI.DynamicField.WeaponTypeLabel"}}</strong> {{item.system.weaponType}}</p>
                    {{/if}}
                    {{#if item.system.personality}}
                      <p><strong>{{localize "DIE_RPG.UI.DynamicField.PersonalityLabel"}}</strong> {{item.system.personality}}</p>
                    {{/if}}
                  {{else if (eq item.type "equipment")}}
                    {{#if item.system.quantity}}
                      <p><strong>{{localize "DIE_RPG.UI.DynamicField.QuantityLabel"}}</strong> {{item.system.quantity}}</p>
                    {{/if}}
                    {{#if item.system.weight}}
                      <p><strong>{{localize "DIE_RPG.UI.DynamicField.WeightLabel"}}</strong> {{item.system.weight}}</p>
                    {{/if}}
                  {{/if}}

                  {{!-- Specials (if item has them) --}}
                  {{#if item.system.specials.length}}
                    <div class="item-specials">
                      <strong>{{localize "DIE_RPG.UI.DynamicField.SpecialsLabel"}}</strong>
                      <ul class="specials-list">
                        {{#each item.system.specials as |special|}}
                          <li class="special-item">
                            <span class="special-name">{{special.name}}</span>
                            <span class="special-cost">{{localize "DIE_RPG.UI.DynamicField.SpecialCost" cost=special.cost}}</span>
                            {{#if special.mandatory}}
                              <span class="tag mandatory">{{localize "DIE_RPG.UI.DynamicField.MandatoryTag"}}</span>
                            {{/if}}
                            {{#if special.description}}
                              <div class="special-desc">{{{special.description}}}</div>
                            {{/if}}
                          </li>
                        {{/each}}
                      </ul>
                    </div>
                  {{/if}}
                </div>
              </div>
            </div>
          {{/each}}
        </div>
      {{else}}
        <p class="hint empty-state">
          <i class="fas fa-info-circle"></i>
          <em>{{localize "DIE_RPG.UI.DynamicField.NoItemsFound" type=../field.itemType}}</em>
        </p>
      {{/if}}
    {{/with}}
    {{#if field.hint}}<p class="hint">{{field.hint}}</p>{{/if}}
  </div>

{{else if (eq field.type "group")}}
  <fieldset class="field-group">
    <legend>{{field.label}}</legend>
    {{#if field.hint}}<p class="hint">{{field.hint}}</p>{{/if}}
    {{#each field.fields as |subfield|}}
      {{> "systems/die-rpg/templates/partials/dynamic-field.hbs"
          field=subfield
          value=(lookup ../value subfield.key)
          enrichedValue=(lookup ../enrichedValue subfield.key)
          path=(concat ../path "." subfield.key)
          editable=../editable
          actor=../actor
          paragonItem=../paragonItem}}
    {{/each}}
  </fieldset>

{{else if (eq field.type "special")}}
  <div class="form-group special-field">
    <label>{{field.label}}</label>
    {{#with (findSpecialByKey paragonItem.system.specials field.specialKey) as |special|}}
      <div class="special-reference">
        <div class="special-header">
          <h4 class="special-name">{{special.name}}</h4>
          <div class="special-tags">
            {{#if special.mandatory}}
              <span class="tag mandatory">{{localize "DIE_RPG.UI.DynamicField.MandatoryTag"}}</span>
            {{/if}}
            <span class="tag cost">{{localize "DIE_RPG.UI.DynamicField.CostTag" cost=special.cost}}</span>
          </div>
        </div>
        <div class="special-description">
          {{{enrichedValue}}}
        </div>
      </div>
    {{else}}
      <div class="special-reference error">
        <p class="hint error">
          <i class="fas fa-exclamation-triangle"></i>
          {{localize "DIE_RPG.UI.DynamicField.SpecialNotFound" key=field.specialKey}}
        </p>
        <p class="hint">{{localize "DIE_RPG.UI.DynamicField.SpecialNotFoundHint" key=field.specialKey}}</p>
      </div>
    {{/with}}
    {{#if field.hint}}<p class="hint">{{field.hint}}</p>{{/if}}
  </div>

{{else}}
  {{!-- Unknown field type --}}
  <div class="form-group error-field">
    <p class="error">{{localize "DIE_RPG.UI.DynamicField.UnknownFieldType" type=field.type}}</p>
    <p class="hint">{{localize "DIE_RPG.UI.DynamicField.UnknownFieldTypeHint"}}</p>
  </div>

{{/if}}
