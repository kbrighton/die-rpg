{{! Advancements Tab }}
<section
  class='tab advancements {{tab.cssClass}}'
  data-group='primary'
  data-tab='advancements'
>

  <div class="advancements-grid">
    <div class="advancement-info">
      {{> "systems/die-rpg/templates/partials/number-spinner.hbs"
        name="system.level"
        label=(localize "DIE_RPG.UI.Labels.Level")
        value=actor.system.level
        min=1
        max=20
      }}
      {{! Advancement Position List }}
      <div class="advancement-positions">
        <ul>
          {{#each config.PARAGON_ADVANCEMENT_MAP.nodes as |node nodeId|}}
            {{#if (ne nodeId "row0-1")}}
              <li>
                <span class="position-id">{{formatNodeId nodeId}}</span>:
                  {{#if (isNodeSelected @root.actor nodeId)}}
                    <span class="position-state selected"><i class="fa-solid fa-check"></i> {{getAdvancementName @root.paragonItem nodeId}}</span>
                  {{else if (eq (getNodeDisabledReason @root.actor nodeId) "locked")}}
                    <span class="position-state locked"><i class="fa-solid fa-lock"></i> {{getAdvancementName @root.paragonItem nodeId}}</span>
                  {{else if (eq (getNodeDisabledReason @root.actor nodeId) "level")}}
                    <span class="position-state level-locked"><i class="fa-solid fa-triangle-exclamation"></i> {{getAdvancementName @root.paragonItem nodeId}}</span>
                  {{else}}
                    <span class="position-state available"><i class="fa-solid fa-lock-open"></i> {{getAdvancementName @root.paragonItem nodeId}}</span>
                  {{/if}}
              </li>
            {{/if}}
          {{/each}}
        </ul>
      </div>
    </div>

    <svg viewBox="{{svgViewBox}}" class="advancement-map" preserveAspectRatio="xMidYMid meet">
      <defs>
        {{! Lock icon }}
        <g id="lock-icon" transform="scale(0.08)">
          <path d="M256 160L256 224L384 224L384 160C384 124.7 355.3 96 320 96C284.7 96 256 124.7 256 160zM192 224L192 160C192 89.3 249.3 32 320 32C390.7 32 448 89.3 448 160L448 224C483.3 224 512 252.7 512 288L512 512C512 547.3 483.3 576 448 576L192 576C156.7 576 128 547.3 128 512L128 288C128 252.7 156.7 224 192 224z"/>
        </g>
        {{! Unlock icon }}
        <g id="unlock-icon" transform="scale(0.08)">
          <path d="M416 160C416 124.7 444.7 96 480 96C515.3 96 544 124.7 544 160L544 192C544 209.7 558.3 224 576 224C593.7 224 608 209.7 608 192L608 160C608 89.3 550.7 32 480 32C409.3 32 352 89.3 352 160L352 224L192 224C156.7 224 128 252.7 128 288L128 512C128 547.3 156.7 576 192 576L448 576C483.3 576 512 547.3 512 512L512 288C512 252.7 483.3 224 448 224L416 224L416 160z"/>
        </g>
      </defs>
    {{#each config.PARAGON_ADVANCEMENT_MAP.nodes as |node nodeId|}}
      <g class="advancement-node" data-node-id="{{nodeId}}">
        {{#if (eq nodeId "row0-1")}}
        {{! START node - always selected, not clickable }}
        <polygon
          points="{{svgTrianglePoints nodeId}}"
          class="triangle selected start-node"
          data-advancement-tooltip="{{localize 'DIE_RPG.UI.Status.Start'}}"
        />
        {{else}}
        <polygon
          points="{{svgTrianglePoints nodeId}}"
          class="triangle
            {{~#if (isNodeSelected @root.actor nodeId)}} selected{{/if~}}
            {{~#if (eq (getNodeDisabledReason @root.actor nodeId) "locked")}} locked{{/if~}}
            {{~#if (eq (getNodeDisabledReason @root.actor nodeId) "level")}} level-locked{{/if~}}
            {{~#if (canSelectNode @root.actor nodeId)}} available{{/if~}}
          "
          {{~#unless (isNodeSelected @root.actor nodeId)}}
            {{~#unless (canSelectNode @root.actor nodeId)}} data-disabled="true"{{/unless~}}
          {{~/unless}}
          data-action="toggleAdvancement"
          data-node-id="{{nodeId}}"
          {{~#if (eq (getNodeDisabledReason @root.actor nodeId) "locked")}}
            data-advancement-tooltip="{{localize 'DIE_RPG.UI.Tooltips.Locked'}}"
          {{~else if (eq (getNodeDisabledReason @root.actor nodeId) "level")}}
            data-advancement-tooltip="{{localize 'DIE_RPG.UI.Tooltips.IncreaseLevelToUnlock'}}"
          {{~else}}
            data-advancement-tooltip="{{getAdvancementName @root.paragonItem nodeId}}"
          {{~/if}}
        />
        {{/if}}
        {{#if (eq nodeId "row0-1")}}
          {{! START node - just show text, no icon }}
          <text
            x="{{svgTextX nodeId}}"
            y="{{svgTextY nodeId}}"
            class="triangle-label start-label"
            text-anchor="middle"
            pointer-events="none"
          >
            <tspan>{{formatNodeId nodeId}}</tspan>
          </text>
        {{else if (eq (getNodeDisabledReason @root.actor nodeId) "locked")}}
          <use href="#lock-icon" x="{{subtract (svgTextX nodeId) 27}}" y="{{subtract (svgTextY nodeId) 75}}" fill="#fff" opacity="0.8"/>
          <text
            x="{{svgTextX nodeId}}"
            y="{{add (svgTextY nodeId) 25}}"
            class="triangle-label"
            text-anchor="middle"
            pointer-events="none"
          >
            <tspan>{{formatNodeId nodeId}}</tspan>
          </text>
        {{else if (canSelectNode @root.actor nodeId)}}
          <use href="#unlock-icon" x="{{subtract (svgTextX nodeId) 27}}" y="{{subtract (svgTextY nodeId) 75}}" fill="#fff" opacity="0.9"/>
          <text
            x="{{svgTextX nodeId}}"
            y="{{add (svgTextY nodeId) 25}}"
            class="triangle-label"
            text-anchor="middle"
            pointer-events="none"
          >
            <tspan>{{formatNodeId nodeId}}</tspan>
          </text>
        {{else}}
          <text
            x="{{svgTextX nodeId}}"
            y="{{svgTextY nodeId}}"
            class="triangle-label"
            text-anchor="middle"
            pointer-events="none"
          >
            <tspan>{{formatNodeId nodeId}}</tspan>
          </text>
        {{/if}}
      </g>
    {{/each}}
    </svg>
  </div>

  {{! Advancement Forms Section - Dynamic Fields from Paragon }}
  {{#if paragonItem.system.advancementForms.fields.length}}
    <div class="advancement-forms-section">
      {{!-- <h3>{{localize "DIE_RPG.UI.Headers.AdvancementForms"}}</h3> --}}
      {{!-- <p class="hint">{{localize "DIE_RPG.UI.Hints.AdvancementFormsHint"}}</p> --}}
      <div class="advancement-forms">
        {{#each paragonItem.system.advancementForms.fields as |field|}}
          {{> "systems/die-rpg/templates/partials/dynamic-field.hbs"
            field=field
            value=(lookup @root.actor.system.paragon.advancementData field.key)
            enrichedValue=(lookup @root.enrichedAdvancementData field.key)
            path=(concat "system.paragon.advancementData." field.key)
            editable=@root.editable
            actor=@root.actor
            paragonItem=@root.paragonItem}}
        {{/each}}
      </div>
    </div>
  {{/if}}
</section>