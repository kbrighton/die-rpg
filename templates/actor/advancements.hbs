{{! Advancements Tab }}
<section
  class='tab advancements {{tab.cssClass}}'
  data-group='primary'
  data-tab='advancements'
>

  <div class="advancements-grid">
    <div class="advancement-info">
      <div class="form-group">
        <label for="level">Level:</label>
        <input
          type="number"
          name="system.level"
          id="level"
          value="{{actor.system.level}}"
          min="1"
          max="20"
          data-type="Number"
        />
      </div>
      <p>Advancements Selected: {{actor.system.paragon.advancements.size}}</p>
      <p>Available Selections: {{subtract actor.system.level actor.system.paragon.advancements.size}}</p>
    </div>

    <svg viewBox="{{svgViewBox}}" class="advancement-map" preserveAspectRatio="xMidYMid meet">
    {{#each config.PARAGON_ADVANCEMENT_MAP.nodes as |node nodeId|}}
      <g class="advancement-node" data-node-id="{{nodeId}}">
        <polygon
          points="{{svgTrianglePoints nodeId}}"
          class="triangle
            {{~#if (isNodeSelected @root.actor nodeId)}} selected{{/if~}}
            {{~#if (eq (getNodeDisabledReason @root.actor nodeId) "locked")}} locked{{/if~}}
            {{~#if (eq (getNodeDisabledReason @root.actor nodeId) "level")}} level-locked{{/if~}}
          "
          {{~#unless (isNodeSelected @root.actor nodeId)}}
            {{~#unless (canSelectNode @root.actor nodeId)}} data-disabled="true"{{/unless~}}
          {{~/unless}}
          data-action="toggleAdvancement"
          data-node-id="{{nodeId}}"
          {{~#if (eq (getNodeDisabledReason @root.actor nodeId) "locked")}}
            data-advancement-tooltip="Locked"
          {{~else if (eq (getNodeDisabledReason @root.actor nodeId) "level")}}
            data-advancement-tooltip="Increase level to unlock"
          {{~else}}
            data-advancement-tooltip="{{getAdvancementName @root.paragonItem nodeId}}"
          {{~/if}}
        />
        <text
          x="{{svgTextX nodeId}}"
          y="{{svgTextY nodeId}}"
          class="triangle-label"
          text-anchor="middle"
          pointer-events="none"
        >
          {{#if (eq (getNodeDisabledReason @root.actor nodeId) "locked")}}
            <tspan class="lock-icon">🔒</tspan>
          {{else}}
            <tspan>{{getAdvancementNumber @root.paragonItem nodeId}}</tspan>
          {{/if}}
        </text>
      </g>
    {{/each}}
    </svg>
  </div>

  {{! Advancement Details Accordion }}
  <div class="advancement-accordion">
    <h3>Advancement Pool</h3>
    {{#each (getAdvancementsWithPositions paragonItem actor) as |item|}}
      <details class="advancement-detail">
        <summary class="advancement-summary">
          <span class="advancement-number">[{{item.advancement.id}}]</span>
          <span class="advancement-name">{{item.advancement.name}}</span>
        </summary>
        <div class="advancement-body">
          {{#if item.advancement.description}}
            <div class="advancement-description">
              {{{item.advancement.description}}}
            </div>
          {{/if}}
          <div class="advancement-positions">
            <strong>Positions on Map:</strong>
            <ul>
              {{#each item.positions as |pos|}}
                <li class="position-{{pos.state}}">
                  <span class="position-id">{{pos.nodeId}}</span>:
                  {{#if pos.selected}}
                    <span class="position-state selected">✓ Selected</span>
                  {{else if (eq pos.state "locked")}}
                    <span class="position-state locked">🔒 Locked</span>
                  {{else if (eq pos.state "level")}}
                    <span class="position-state level-locked">⚠ Level Required</span>
                  {{else}}
                    <span class="position-state available">○ Available</span>
                  {{/if}}
                </li>
              {{/each}}
            </ul>
          </div>
        </div>
      </details>
    {{/each}}
  </div>
</section>