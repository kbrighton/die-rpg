<form>
	<div class="form-group">
		<label>{{localize "DIE_RPG.Dialog.Advantages"}}:</label>
		<input type="number" name="advantages" id="advantages" value="0" min="0" />
	</div>
	<div class="form-group">
		<label>{{localize "DIE_RPG.Dialog.Disadvantages"}}:</label>
		<input
			type="number"
			name="disadvantages"
			id="disadvantages"
			value="0"
			min="0"
		/>
	</div>
	<div class="form-group">
		<label>{{localize "DIE_RPG.Dialog.Difficulty"}}:</label>
		<input
			type="number"
			name="difficulty"
			id="difficulty"
			value="0"
			min="0"
			max="2"
		/>
	</div>
		{{#if classDieType}} {{!-- Only show if a class die exists --}}
		 <div class="form-group">
		    {{#if isZeroPool}}
		      <label>{{localize "DIE_RPG.Dialog.SubstituteClassDie"}}? ({{classDieType}})</label>
		    {{else}}
		      <label>{{localize "DIE_RPG.Dialog.AddClassDie"}}? ({{classDieType}})</label>
		    {{/if}}
		  <input type="checkbox" name="addClassDie" id="addClassDie"/> {{!-- No need for disabled if group is hidden --}}
		 </div>
		{{/if}}
</form>