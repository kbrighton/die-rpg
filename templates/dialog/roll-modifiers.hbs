<form>
	<div class="form-group">
		<label>{{localize "DIE_RPG.Dialog.Advantages"}}:</label>
		<input type="number" name="advantages" id="advantages" value="0" min="0" />
	</div>
	<div class="form-group">
		<label>{{localize "DIE_RPG.Dialog.Disadvantages"}}:</label>
		<input
			type="number"
			name="disadvantages"
			id="disadvantages"
			value="0"
			min="0"
		/>
	</div>
	<div class="form-group">
		<label>{{localize "DIE_RPG.Dialog.Difficulty"}}:</label>
		<input
			type="number"
			name="difficulty"
			id="difficulty"
			value="0"
			min="0"
			max="2"
		/>
	</div>
		{{#if classDieType}} {{!-- Only show if a class die exists --}}
		 <div class="form-group">
		    <label>
		      {{#if isZeroPool}}
		        {{localize "DIE_RPG.Dialog.SubstituteClassDie"}}?
		      {{else}}
		        {{localize "DIE_RPG.Dialog.AddClassDie"}}?
		      {{/if}}
		       ({{classDieType}})
		    </label>
		  <input type="checkbox" name="addClassDie" id="addClassDie"/>
		 </div>
		{{/if}}
</form>