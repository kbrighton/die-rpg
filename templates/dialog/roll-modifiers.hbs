<form>
	<div class="form-group">
		<label>{{localize "DIE_RPG.Dialog.Advantages"}}:</label>
		<input type="number" name="advantages" id="advantages" value="0" min="0" />
	</div>
	<div class="form-group">
		<label>{{localize "DIE_RPG.Dialog.Disadvantages"}}:</label>
		<input
			type="number"
			name="disadvantages"
			id="disadvantages"
			value="0"
			min="0"
		/>
	</div>
	<div class="form-group">
		<label>{{localize "DIE_RPG.Dialog.Difficulty"}}:</label>
		<input
			type="number"
			name="difficulty"
			id="difficulty"
			value="0"
			min="0"
			max="2"
		/>
	</div>
	<div class="form-group">
	   {{#if isZeroPool}}
	     <label>{{localize "DIE_RPG.Dialog.SubstituteClassDie"}}? {{#if classDieType}}({{classDieType}}){{else}}(None Available){{/if}}</label>
	   {{else}}
	     <label>{{localize "DIE_RPG.Dialog.AddClassDie"}}? {{#if classDieType}}({{classDieType}}){{else}}(None Available){{/if}}</label>
	   {{/if}}
		<input type="checkbox" name="addClassDie" id="addClassDie" {{#unless classDieType}}disabled{{/unless}}/>
	</div>
</form>