<div class="die-rpg-roll">
  {{!-- Header --}}
  <div class="roll-header">
    <strong>{{localize "DIE_RPG.Chat.RollMessage.Rolled"}} {{label}}</strong>
  </div>

  {{!-- Pool Display with Badges --}}
  <div class="pool-display">
    <span class="pool-label">{{localize "DIE_RPG.Chat.RollMessage.Pool"}}</span>
    <div class="pool-badges">
      {{#if isZeroPool}}
        {{!-- Zero Pool Badge (Red) --}}
        <span class="dice-badge zero-pool">
          {{#if isSubstituted}}1d6{{else}}2d6{{/if}}
        </span>
      {{else}}
        {{!-- Normal Pool Badge (Green) --}}
        <span class="dice-badge base-pool">{{calculatedPoolSize}}d6</span>
      {{/if}}

      {{!-- Class Die Badge (Orange) --}}
      {{#if addClassDie}}
        <span class="dice-badge class-die">+1{{classDieType}}</span>
      {{/if}}

      {{!-- Flashback Badge --}}
      {{#if flashbackUsed}}
        <span class="dice-badge flashback">{{localize "DIE_RPG.Chat.FlashbackUsed"}}</span>
      {{/if}}
    </div>
  </div>

  {{!-- Dice Results Display --}}
  <div class="dice-display">
    <div class="dice-label">{{localize "DIE_RPG.Chat.RollMessage.DiceRolled"}}</div>
    <div class="dice-results">
      {{#each diceResults}}
        <span
          class="roll die {{dieType}}
            {{#if (gte result 6)}}special-die success{{else}}{{#if (gte result 4)}}success{{/if}}{{/if}}
            {{#if (eq result 1)}}critfail-die{{/if}}
            {{#unless active}}discarded{{/unless}}
            {{#if crossedOut}}crossed-out{{/if}}"
          data-die-index="{{@index}}"
          data-die-value="{{result}}"
          data-die-type="{{dieType}}"
          data-is-active="{{active}}"
          data-crossed-out="{{crossedOut}}"
          title="{{#if (gte result 6)}}{{localize 'DIE_RPG.Chat.DiceTooltips.Special'}}{{else}}{{#if (gte result 4)}}{{localize 'DIE_RPG.Chat.DiceTooltips.Success'}}{{else}}{{localize 'DIE_RPG.Chat.DiceTooltips.Failure'}}{{/if}}{{/if}}">
          <img src="{{getDieIconPath dieType}}" class="die-icon" alt="{{dieType}}">
          <span class="die-value">{{result}}</span>
        </span>
      {{/each}}
    </div>
  </div>

  {{!-- Success Tracking --}}
  <div class="success-tracking">
    <div class="success-row">
      <span class="label">{{localize "DIE_RPG.Chat.RollMessage.InitialSuccesses"}}</span>
      <span class="value">{{initialSuccesses}}</span>
    </div>
    <div class="difficulty-row">
      <span class="label">{{localize "DIE_RPG.Chat.RollMessage.Difficulty"}}</span>
      <span class="value">{{difficulty}}</span>
    </div>
  </div>

  {{!-- Result Display --}}
  <div class="roll-result">
    {{#if isCriticalFail}}
      {{#if showCriticalFail}}
        <div class="result-text critical-fail">
          <i class="fas fa-skull-crossbones"></i>
          <strong>{{localize "DIE_RPG.Chat.Results.CriticalFail"}}</strong>
          <span class="result-detail">{{localize "DIE_RPG.Chat.Results.CriticalFailDetail"}}</span>
        </div>
      {{else}}
        <div class="result-text failure">
          <strong>{{localize "DIE_RPG.Chat.Results.Failure"}}</strong>
          <span class="result-detail">{{localize "DIE_RPG.Chat.Results.FailureDetail"}}</span>
        </div>
      {{/if}}
    {{else}}
      {{#if (gt finalSuccesses 0)}}
        <div class="result-text success">
          <i class="fas fa-check-circle"></i>
          <strong>{{localize "DIE_RPG.Chat.Results.Success"}}</strong>
          <span class="result-detail">({{finalSuccesses}} {{localize "DIE_RPG.Chat.Results.FinalSuccess"}}{{#unless (eq finalSuccesses 1)}}es{{/unless}})</span>
        </div>
      {{else}}
        {{!-- Check for Failing Forward --}}
        {{#if (and showFailingForward (gt initialSuccesses 0) (gte difficulty initialSuccesses))}}
          <div class="result-text failing-forward">
            <i class="fas fa-exclamation-triangle"></i>
            <strong>{{localize "DIE_RPG.Chat.Results.FailForward"}}</strong>
            <span class="result-detail">({{initialSuccesses}} {{localize "DIE_RPG.Chat.Results.FailForwardSuccesses"}} {{difficulty}}. {{localize "DIE_RPG.Chat.Results.FailForwardNote"}})</span>
          </div>
        {{else}}
          <div class="result-text failure">
            <strong>{{localize "DIE_RPG.Chat.Results.Failure"}}</strong>
            <span class="result-detail">{{localize "DIE_RPG.Chat.Results.FailureDetail"}}</span>
          </div>
        {{/if}}
      {{/if}}
    {{/if}}
  </div>

  {{!-- Specials Display --}}
  {{#if (and availableSpecials (gt specialDice 0))}}
    <div class="specials-section">
      <div class="specials-header">
        <i class="fas fa-star"></i>
        <strong>{{localize "DIE_RPG.Chat.AvailableSpecials.Header"}}</strong>
        <span class="specials-count">({{specialDice}} dice rolled 6+)</span>
      </div>
      <ul class="specials-list">
        {{#each availableSpecials}}
          {{#if (gte ../specialDice costValue)}}
            <li class="special-item {{#if mandatory}}mandatory{{/if}}"
                title="{{description}}"
                data-special-source="{{_source.itemId}}"
                data-special-name="{{name}}">
              <div class="special-content">
                <span class="special-icon">
                  {{#if mandatory}}
                    <i class="fas fa-exclamation-circle"></i>
                  {{else}}
                    <i class="fas fa-star"></i>
                  {{/if}}
                </span>
                <span class="special-name">{{name}}</span>
                <span class="special-cost dice-badge">{{localize "DIE_RPG.Chat.AvailableSpecials.CostLabel"}} {{costValue}}</span>
                {{#if mandatory}}
                  <span class="mandatory-badge">{{localize "DIE_RPG.Chat.AvailableSpecials.MandatoryBadge"}}</span>
                {{/if}}
              </div>
              <div class="special-source">
                <em>{{_source.itemName}}</em>
              </div>
            </li>
          {{/if}}
        {{/each}}
      </ul>
    </div>
  {{/if}}

  {{!-- Future Feature Stub: Interactive Dice Crossing Out --}}
  {{!-- Will be enabled via enableDiceInteraction setting --}}
</div>
