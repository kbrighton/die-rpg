{
  "id": "die-rpg",
  "title": "DIE: The Roleplaying Game",
  "description": "The DIE: The Roleplaying Game system for FoundryVTT",
  "authors": [
    {
      "name": "ephson",
      "url": "https://github.com/philote",
      "discord": "ephson",
      "reddit": "u/ephson"
    }
  ],
  "documentTypes": {
    "Actor": {
        "character": {
            "htmlFields": ["biography"]
        },
        "npc": {
            "htmlFields": ["biography"]
        }
    },
    "Item": {
        "feature": {
            "htmlFields": ["description"]
        },
        "gear": {
            "htmlFields": ["description"]
        },
        "ability": {
            "htmlFields": ["description", "effectDescription"]
        },
        "class": {
            "htmlFields": ["description"]
        },
        "persona": {
            "htmlFields": ["description"]
        }
    }
  },
  "flags": {
    "hotReload": {
      "extensions": ["css", "html", "hbs", "json"],
      "paths": ["css", "lang", "templates"]
    }
  },
  "license": "LICENSE.txt",
  "readme": "README.md",
  "bugs": "https://github.com/philote/die-rpg/issues",
  "changelog": "CHANGELOG.md",
  "version": "#{VERSION}#",
  "compatibility": {
    "minimum": 13,
    "verified": 13.348
  },
  "esmodules": ["module/die-rpg.mjs"],
  "styles": ["css/die-rpg.css"],
  "languages": [
    {
      "lang": "en",
      "name": "English",
      "path": "lang/en.json"
    }
  ],
  "packs": [],
  "packFolders": [],
  "socket": false,
  "url": "#{URL}#",
	"manifest": "#{MANIFEST}#",
	"download": "#{DOWNLOAD}#",
  "background": "systems/die-rpg/assets/cover.webp",
  "primaryTokenAttribute": "health",
  "secondaryTokenAttribute": null,
  "media": [
    {
      "type": "setup",
      "url": "systems/die-rpg/assets/package_image.webp",
      "thumbnail": "systems/die-rpg/assets/package_image_thumb.webp"
    }
  ]
}
