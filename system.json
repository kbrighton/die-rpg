{
  "id": "die-rpg",
  "title": "DIE: The Roleplaying Game",
  "description": "The DIE: The Roleplaying Game system for FoundryVTT",
  "authors": [
    {
      "name": "ephson",
      "url": "https://github.com/philote",
      "discord": "ephson",
      "reddit": "u/ephson"
    }
  ],
  "documentTypes": {
    "Actor": {
        "character": {
            "htmlFields": ["notes", "persona.notes", "paragon.nature", "paragon.coreAbility.description"],
            "filePathFields": {
              "persona.img": ["IMAGE"]
            }
        },
        "npc": {
            "htmlFields": ["notes"]
        }
    },
    "Item": {
        "equipment": {
            "htmlFields": ["description"]
        },
        "paragon": {
            "htmlFields": ["description", "coreNature", "coreAbility.description", "advancements.*.description", "specials.*.description"],
            "filePathFields": {
              "classDiceImage": ["IMAGE"],
              "portraitImage": ["IMAGE"],
              "tokenImage": ["IMAGE"]
            }
        },
        "look": {
            "htmlFields": ["description"]
        },
        "spell": {
            "htmlFields": ["description", "specials.*.description"]
        },
        "god": {
            "htmlFields": ["description", "scriptures.*.description", "scriptures.*.specials.*.description"]
        },
        "gift": {
            "htmlFields": ["description", "upgrades.*.description", "upgrades.*.specials.*.description"]
        },
        "stance": {
            "htmlFields": ["description", "specials.*.description"]
        },
        "venting": {
            "htmlFields": ["description"]
        },
        "arcaneweapon": {
            "htmlFields": ["description"]
        }
    }
  },
  "flags": {
    "hotReload": {
      "extensions": ["css", "html", "hbs", "json"],
      "paths": ["css", "lang", "templates"]
    }
  },
  "license": "LICENSE.txt",
  "readme": "README.md",
  "bugs": "https://github.com/philote/die-rpg/issues",
  "changelog": "https://github.com/philote/die-rpg/releases",
  "version": "#{VERSION}#",
  "compatibility": {
    "minimum": 13,
    "verified": 13.350,
    "maximum": 13
  },
  "esmodules": ["module/die-rpg.mjs"],
  "styles": ["css/die-rpg.css"],
  "languages": [
    {
      "lang": "en",
      "name": "English",
      "path": "lang/en.json"
    }
  ],
  "packs": [
    {
      "name": "equipment",
      "label": "Equipment",
      "path": "packs/equipment",
      "type": "Item",
      "system": "die-rpg",
      "ownership": {
        "PLAYER": "OBSERVER",
        "ASSISTANT": "OWNER"
      }
    },
    {
      "name": "paragons",
      "label": "Paragons",
      "path": "packs/paragons",
      "type": "Item",
      "system": "die-rpg",
      "ownership": {
        "PLAYER": "OBSERVER",
        "ASSISTANT": "OWNER"
      }
    },
    {
      "name": "gods",
      "label": "Gods",
      "path": "packs/gods",
      "type": "Item",
      "system": "die-rpg",
      "ownership": {
        "PLAYER": "OBSERVER",
        "ASSISTANT": "OWNER"
      }
    },
    {
      "name": "gifts",
      "label": "Gifts of the Fair",
      "path": "packs/gifts",
      "type": "Item",
      "system": "die-rpg",
      "ownership": {
        "PLAYER": "OBSERVER",
        "ASSISTANT": "OWNER"
      }
    },
    {
      "name": "stances",
      "label": "Stances",
      "path": "packs/stances",
      "type": "Item",
      "system": "die-rpg",
      "ownership": {
        "PLAYER": "OBSERVER",
        "ASSISTANT": "OWNER"
      }
    },
    {
      "name": "venting",
      "label": "Venting Abilities",
      "path": "packs/venting",
      "type": "Item",
      "system": "die-rpg",
      "ownership": {
        "PLAYER": "OBSERVER",
        "ASSISTANT": "OWNER"
      }
    },
    {
      "name": "spells",
      "label": "Spells",
      "path": "packs/spells",
      "type": "Item",
      "system": "die-rpg",
      "ownership": {
        "PLAYER": "OBSERVER",
        "ASSISTANT": "OWNER"
      }
    }
  ],
  "packFolders": [],
  "socket": false,
  "url": "#{URL}#",
	"manifest": "#{MANIFEST}#",
	"download": "#{DOWNLOAD}#",
  "background": "systems/die-rpg/assets/cover.webp",
  "primaryTokenAttribute": "resources.health",
  "secondaryTokenAttribute": "resources.guard",
  "media": [
    {
      "type": "setup",
      "url": "systems/die-rpg/assets/package_image.webp",
      "thumbnail": "systems/die-rpg/assets/package_image_thumb.webp"
    }
  ]
}
